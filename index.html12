li class="tz-navigation__list-item" itemprop="name"><a href="#overview">Overview</a></li><li class="tz-navigation__list-item" itemprop="name"><a href="#programs">Programs</a></li><li class="tz-navigation__list-item" itemprop="name"><a href="#career-opportunities">Career</a></li><li class="tz-navigation__list-item" itemprop="name"><a href="#why-choose">Why Choose?</a></li><li class="tz-navigation__list-item" itemprop="name"><a href="#recruiters">Recruiters</a></li><li class="tz-navigation__list-item" itemprop="name"><a href="#collaboration">Affiliation</a></li><li class="tz-navigation__list-item" itemprop="name"><a href="#events">Events</a></li><li class="tz-navigation__list-item" itemprop="name"><a href="#faq">FAQ</a></li></ul></nav></aside><!-- header end--><main role="main"><!-- hero start--><section class="tz-container tz-container--full-bleed tz-hero-section tz-scrollspy" id="overview"><div class="tz-hero-content__root"><img class="tz-hero-section__bg" id="tz-hero-section__bg" src="/assets/admissions/school-of-engineering-and-technology/banner.20_03_2025.webp" alt="School of Engineering and Technology" fetchpriority="high" style="--tz-object-position-desktop:center;--tz-object-position-mobile:right" decoding="async" width="3568" height="1112" srcset="/assets/admissions/school-of-engineering-and-technology/banner.20_03_2025.webp 3568w, /assets/admissions/school-of-engineering-and-technology/banner.20_03_2025@3268w.webp 3268w, /assets/admissions/school-of-engineering-and-technology/banner.20_03_2025@2968w.webp 2968w, /assets/admissions/school-of-engineering-and-technology/banner.20_03_2025@2668w.webp 2668w, /assets/admissions/school-of-engineering-and-technology/banner.20_03_2025@2368w.webp 2368w, /assets/admissions/school-of-engineering-and-technology/banner.20_03_2025@2068w.webp 2068w, /assets/admissions/school-of-engineering-and-technology/banner.20_03_2025@1768w.webp 1768w, /assets/admissions/school-of-engineering-and-technology/banner.20_03_2025@1468w.webp 14